NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://trackall:trackall_pass@localhost:5432/trackall_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=trackall_db
DB_USER=trackall
DB_PASSWORD=trackall_pass

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6

# Twilio (SMS OTP)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+91XXXXXXXXXX

# Email (Nodemailer / Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM="TrackAll <noreply@trackall.in>"

# Courier APIs
SHIPROCKET_EMAIL=your-shiprocket-email
SHIPROCKET_PASSWORD=your-shiprocket-password
AFTERSHIP_API_KEY=your-aftership-api-key
DELHIVERY_API_KEY=your-delhivery-api-key

# Frontend URL (CORS)
FRONTEND_URL=http://localhost:3000
